NODE_ENV=development
PORT=5000

# MongoDB Atlas URI
# If your password contains special characters like @ # $ % : / ? & =, encode them first.
# Example: my@pass#123 -> my%40pass%23123
MONGO_URI=mongodb://127.0.0.1:27017/sgip
# Legacy fallback supported by the app:
# MONGODB_URI=mongodb://127.0.0.1:27017/sgip

FRONTEND_URL=http://localhost:5173
# Optional comma-separated extra origins, useful for Vercel production + preview URLs.
FRONTEND_URLS=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

JWT_SECRET=
JWT_EXPIRES_IN=7d

# SMTP settings are optional on Render.
# If these are missing, the backend still starts and OTP routes return a clean 503.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Brevo Transactional Email API. Recommended for Render because it avoids SMTP socket timeouts.
EMAIL_PROVIDER=brevo_api
BREVO_API_KEY=
BREVO_FROM=

# Brevo SMTP relay. Set EMAIL_PROVIDER=brevo to use these instead of SMTP_*.
# BREVO_SMTP_HOST can usually stay empty because the app defaults to smtp-relay.brevo.com.
BREVO_SMTP_HOST=
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_KEY=
EMAIL_SEND_TIMEOUT_MS=30000
OTP_EXPIRES_IN_MINUTES=10

AI_PROVIDER=gemini
AI_MODEL=
AI_API_KEY=
AI_TIMEOUT_MS=15000
RESUME_MAX_FILE_SIZE_MB=5

ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@sgip.com
ADMIN_PASSWORD=ChangeMeStrong123
